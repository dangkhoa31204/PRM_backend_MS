# ─── DATABASE PASSWORDS ──────────────────────────────────────────────────────
# Đặt mật khẩu an toàn cho các Postgres Databases ở Production
DB_IDENTITY_PASSWORD=YourSecurePassword1Here
DB_RESTAURANT_PASSWORD=YourSecurePassword2Here
DB_ORDER_PASSWORD=YourSecurePassword3Here

# ─── JWT CONFIGURATION ───────────────────────────────────────────────────────
# Tạo một chuỗi JWT Key dài hơn 32 ký tự, tuyệt đối bí mật
JWT_KEY=YourSuperSecretKeyWithAtLeast32CharactersForProduction2026!
JWT_ISSUER=PRM.Services.Identity
JWT_AUDIENCE=PRM.Services

# ─── GATEWAY URL ─────────────────────────────────────────────────────────────
# Đường dẫn API Gateway chính thức. 
# Ví dụ nếu dùng domain: https://api.prm-order.com
# Hoặc nếu dùng IP Public: http://your-vps-ip:5000
APP_BASE_URL=http://your-vps-ip:5000
